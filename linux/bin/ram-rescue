#!/usr/bin/env bash
# ram-rescue — low-memory alerter for Linux desktops.
# Invoked periodically by ram-rescue.timer. Exits silently when memory is fine.

set -euo pipefail

VERSION="0.4.1"

# Locate and source the classifier library.
_RR_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -r "$_RR_SCRIPT_DIR/../lib/classify.sh" ]]; then
  # shellcheck disable=SC1091
  source "$_RR_SCRIPT_DIR/../lib/classify.sh"
elif [[ -r "$_RR_SCRIPT_DIR/classify.sh" ]]; then
  # Installed layout: lib and bin merged into one PREFIX dir.
  # shellcheck disable=SC1091
  source "$_RR_SCRIPT_DIR/classify.sh"
else
  echo "ERROR: classify.sh not found alongside ram-rescue" >&2
  exit 1
fi

# ---------------------------------------------------------------- config
THRESHOLD_PCT=15
COOLDOWN_SEC=600
SNOOZE_DURATION=1800
MONITOR_CMD=""

# shellcheck disable=SC1091
[[ -r /etc/ram-rescue/config ]] && source /etc/ram-rescue/config
# shellcheck disable=SC1091
[[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/ram-rescue/config" ]] &&
  source "${XDG_CONFIG_HOME:-$HOME/.config}/ram-rescue/config"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/ram-rescue"
QUIET_UNTIL_FILE="$STATE_DIR/quiet-until"
mkdir -p "$STATE_DIR"

# ---------------------------------------------------------------- desktop detection
detect_monitor_cmd() {
  if [[ -n "$MONITOR_CMD" ]]; then
    return
  fi
  case "${XDG_CURRENT_DESKTOP:-}" in
    *GNOME* | *Unity* | *Cinnamon*) MONITOR_CMD="gnome-system-monitor" ;;
    *KDE* | *Plasma*)
      if command -v plasma-systemmonitor >/dev/null 2>&1; then
        MONITOR_CMD="plasma-systemmonitor"
      else
        MONITOR_CMD="ksysguard"
      fi
      ;;
    *XFCE*) MONITOR_CMD="xfce4-taskmanager" ;;
    *MATE*) MONITOR_CMD="mate-system-monitor" ;;
    *)
      if command -v gnome-terminal >/dev/null 2>&1; then
        MONITOR_CMD="gnome-terminal -- htop"
      elif command -v xterm >/dev/null 2>&1; then
        MONITOR_CMD="xterm -e htop"
      else
        MONITOR_CMD=""
      fi
      ;;
  esac
}

# ---------------------------------------------------------------- memory check
read_memory() {
  local total avail
  total=$(awk '/^MemTotal:/{print $2}' /proc/meminfo)
  avail=${MEMAVAILABLE_OVERRIDE:-$(awk '/^MemAvailable:/{print $2}' /proc/meminfo)}
  if [[ -z "$total" || -z "$avail" ]]; then
    logger -t ram-rescue "ERROR: could not read /proc/meminfo"
    exit 1
  fi
  MEM_TOTAL_KB=$total
  MEM_AVAIL_KB=$avail
  MEM_PCT=$((avail * 100 / total))
}

# ---------------------------------------------------------------- quiet window
in_quiet_window() {
  [[ -f "$QUIET_UNTIL_FILE" ]] || return 1
  local quiet_until now
  quiet_until=$(<"$QUIET_UNTIL_FILE")
  now=$(date +%s)
  ((quiet_until > now))
}

set_quiet_window() {
  local duration=$1
  echo "$(($(date +%s) + duration))" >"$QUIET_UNTIL_FILE"
}

# ---------------------------------------------------------------- top apps (top 5 for notification)
top_apps() {
  declare -A APP_RSS APP_COUNT APP_EMOJI APP_DESC APP_CAT
  local APP_SORTED=""
  build_app_table

  local count=0 chrome_tabs=-1 rss name mb_disp extra
  while IFS=$'\t' read -r rss name; do
    ((count >= 5)) && break
    [[ -z "$name" ]] && continue

    mb_disp=$(format_size "$rss")

    extra="${APP_DESC[$name]}"
    if [[ "$name" == "Chrome" || "$name" == "Chromium" || "$name" == "Brave" ]]; then
      if ((chrome_tabs < 0)); then chrome_tabs=$(count_chrome_tabs); fi
      if ((chrome_tabs > 0)); then
        extra="~${chrome_tabs} tabs"
      fi
    fi

    printf '%s %s · %s · %s\n' "${APP_EMOJI[$name]}" "$name" "$mb_disp" "$extra"
    count=$((count + 1))
  done <<<"$APP_SORTED"
}

# ---------------------------------------------------------------- alert
fire_alert() {
  local apps severity body title action
  severity=$(severity_emoji "$MEM_PCT")
  apps=$(top_apps)
  title="${severity} Low memory · ${MEM_PCT}% available"
  body=$(printf '%d MB free of %d MB · Top apps:\n\n%s' \
    "$((MEM_AVAIL_KB / 1024))" "$((MEM_TOTAL_KB / 1024))" "$apps")

  if [[ "${XDG_CURRENT_DESKTOP:-}" == *XFCE* ]]; then
    body+=$'\n\nRun `ram-rescue open` to launch the monitor.'
  fi

  action=$(timeout 45s notify-send \
    --app-name=ram-rescue \
    --urgency=critical \
    --icon=dialog-warning \
    --wait \
    --expire-time=30000 \
    --action="open=Open Monitor" \
    --action="snooze=Snooze 30m" \
    "$title" \
    "$body" 2>/dev/null) || action=""

  case "$action" in
    open)
      detect_monitor_cmd
      if [[ -n "$MONITOR_CMD" ]]; then
        # shellcheck disable=SC2086
        nohup $MONITOR_CMD >/dev/null 2>&1 &
        logger -t ram-rescue "user opened monitor: $MONITOR_CMD"
      else
        logger -t ram-rescue "WARN: no monitor command available for desktop ${XDG_CURRENT_DESKTOP:-unknown}"
      fi
      set_quiet_window "$COOLDOWN_SEC"
      ;;
    snooze)
      set_quiet_window "$SNOOZE_DURATION"
      logger -t ram-rescue "user snoozed for ${SNOOZE_DURATION}s"
      ;;
    *)
      set_quiet_window "$COOLDOWN_SEC"
      ;;
  esac

  logger -t ram-rescue "alert pct=${MEM_PCT} avail=${MEM_AVAIL_KB}kB action=${action:-none}"
}

# ---------------------------------------------------------------- main
main() {
  read_memory
  if ((MEM_PCT >= THRESHOLD_PCT)); then
    exit 0
  fi
  if in_quiet_window; then
    exit 0
  fi
  fire_alert
}

case "${1:-}" in
  --version) echo "ram-rescue $VERSION" ;;
  --apps)
    read_memory
    severity=$(severity_emoji "$MEM_PCT")
    printf '%s Memory: %d%% available (%d MB free of %d MB)\n\nTop apps:\n\n' \
      "$severity" "$MEM_PCT" "$((MEM_AVAIL_KB / 1024))" "$((MEM_TOTAL_KB / 1024))"
    top_apps
    ;;
  --help)
    cat <<'EOF'
ram-rescue — low-memory alerter for Linux desktops.

Invoked periodically by the ram-rescue.timer systemd-user unit. Reads
/proc/meminfo and fires a desktop notification when MemAvailable drops
below the configured threshold.

Use `ram-rescue` (the CLI) for status, test, apps, overlay, etc.

Flags:
  --apps      Print the grouped top-apps view to stdout (no notification)
  --version   Print version
  --help      This message

Env vars:
  MEMAVAILABLE_OVERRIDE=<kB>   force a low-memory condition for testing
EOF
    ;;
  *) main ;;
esac
