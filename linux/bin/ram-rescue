#!/usr/bin/env bash
# ram-rescue тАФ low-memory alerter for Linux desktops.
# Invoked periodically by ram-rescue.timer. Exits silently when memory is fine.

set -euo pipefail

VERSION="0.3.0"

# ---------------------------------------------------------------- config
THRESHOLD_PCT=15
COOLDOWN_SEC=600
SNOOZE_DURATION=1800
MONITOR_CMD=""

# shellcheck disable=SC1091
[[ -r /etc/ram-rescue/config ]] && source /etc/ram-rescue/config
# shellcheck disable=SC1091
[[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/ram-rescue/config" ]] &&
  source "${XDG_CONFIG_HOME:-$HOME/.config}/ram-rescue/config"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/ram-rescue"
QUIET_UNTIL_FILE="$STATE_DIR/quiet-until"
mkdir -p "$STATE_DIR"

# ---------------------------------------------------------------- desktop detection
detect_monitor_cmd() {
  if [[ -n "$MONITOR_CMD" ]]; then
    return
  fi
  case "${XDG_CURRENT_DESKTOP:-}" in
    *GNOME* | *Unity* | *Cinnamon*) MONITOR_CMD="gnome-system-monitor" ;;
    *KDE* | *Plasma*)
      if command -v plasma-systemmonitor >/dev/null 2>&1; then
        MONITOR_CMD="plasma-systemmonitor"
      else
        MONITOR_CMD="ksysguard"
      fi
      ;;
    *XFCE*) MONITOR_CMD="xfce4-taskmanager" ;;
    *MATE*) MONITOR_CMD="mate-system-monitor" ;;
    *)
      if command -v gnome-terminal >/dev/null 2>&1; then
        MONITOR_CMD="gnome-terminal -- htop"
      elif command -v xterm >/dev/null 2>&1; then
        MONITOR_CMD="xterm -e htop"
      else
        MONITOR_CMD=""
      fi
      ;;
  esac
}

# ---------------------------------------------------------------- memory check
read_memory() {
  local total avail
  total=$(awk '/^MemTotal:/{print $2}' /proc/meminfo)
  avail=${MEMAVAILABLE_OVERRIDE:-$(awk '/^MemAvailable:/{print $2}' /proc/meminfo)}
  if [[ -z "$total" || -z "$avail" ]]; then
    logger -t ram-rescue "ERROR: could not read /proc/meminfo"
    exit 1
  fi
  MEM_TOTAL_KB=$total
  MEM_AVAIL_KB=$avail
  MEM_PCT=$((avail * 100 / total))
}

# ---------------------------------------------------------------- quiet window
in_quiet_window() {
  [[ -f "$QUIET_UNTIL_FILE" ]] || return 1
  local quiet_until now
  quiet_until=$(<"$QUIET_UNTIL_FILE")
  now=$(date +%s)
  ((quiet_until > now))
}

set_quiet_window() {
  local duration=$1
  echo "$(($(date +%s) + duration))" >"$QUIET_UNTIL_FILE"
}

# ---------------------------------------------------------------- app classifier
# Maps a process `comm` to "AppName<TAB>Emoji<TAB>Description<TAB>Category".
# First match wins. Unknown processes fall through to "$comm + package emoji".
classify_app() {
  case "$1" in
    chrome | chromium | google-chrome* | chromium-browser)
      printf '%s\t%s\t%s\t%s\n' "Chrome" "ЁЯМР" "Web browser" "browser" ;;
    firefox*)
      printf '%s\t%s\t%s\t%s\n' "Firefox" "ЁЯжК" "Web browser" "browser" ;;
    brave | brave-browser)
      printf '%s\t%s\t%s\t%s\n' "Brave" "ЁЯжБ" "Web browser" "browser" ;;
    opera | Opera)
      printf '%s\t%s\t%s\t%s\n' "Opera" "ЁЯФ╡" "Web browser" "browser" ;;
    Code | code | code-insiders | codium | VSCodium)
      printf '%s\t%s\t%s\t%s\n' "VS Code" "ЁЯУЭ" "Code editor" "editor" ;;
    cursor | Cursor)
      printf '%s\t%s\t%s\t%s\n' "Cursor" "тЬи" "AI code editor" "editor" ;;
    claude)
      printf '%s\t%s\t%s\t%s\n' "Claude Code" "ЁЯдЦ" "Anthropic AI agent" "ai" ;;
    aider)
      printf '%s\t%s\t%s\t%s\n' "Aider" "ЁЯдЦ" "AI pair programmer" "ai" ;;
    openclaw | clawd)
      printf '%s\t%s\t%s\t%s\n' "OpenClaw" "ЁЯжЮ" "AI gateway" "ai" ;;
    slack)
      printf '%s\t%s\t%s\t%s\n' "Slack" "ЁЯТм" "Team chat" "chat" ;;
    discord | Discord)
      printf '%s\t%s\t%s\t%s\n' "Discord" "ЁЯОо" "Chat app" "chat" ;;
    telegram-desktop | Telegram)
      printf '%s\t%s\t%s\t%s\n' "Telegram" "тЬИя╕П" "Chat app" "chat" ;;
    spotify | Spotify)
      printf '%s\t%s\t%s\t%s\n' "Spotify" "ЁЯО╡" "Music streaming" "media" ;;
    zoom | Zoom | zoom.us)
      printf '%s\t%s\t%s\t%s\n' "Zoom" "ЁЯОе" "Video calls" "media" ;;
    obs | OBS | obs-studio)
      printf '%s\t%s\t%s\t%s\n' "OBS Studio" "ЁЯУ╣" "Streaming/recording" "media" ;;
    vlc | VLC)
      printf '%s\t%s\t%s\t%s\n' "VLC" "ЁЯОм" "Media player" "media" ;;
    node | nodejs)
      printf '%s\t%s\t%s\t%s\n' "Node.js" "тЪЩя╕П" "JavaScript runtime" "runtime" ;;
    npm | "npm exec"* | "npm run"*)
      printf '%s\t%s\t%s\t%s\n' "npm" "ЁЯУж" "npm-managed Node process" "runtime" ;;
    "next-server"*)
      printf '%s\t%s\t%s\t%s\n' "Next.js dev" "тЦ▓" "Next.js development server" "server" ;;
    "vite"* | esbuild)
      printf '%s\t%s\t%s\t%s\n' "Vite/esbuild" "тЪб" "Frontend dev tooling" "server" ;;
    webpack*)
      printf '%s\t%s\t%s\t%s\n' "webpack" "ЁЯУж" "Bundler" "runtime" ;;
    python | python3 | python3.* | python2 | python2.*)
      printf '%s\t%s\t%s\t%s\n' "Python" "ЁЯРН" "Python interpreter" "runtime" ;;
    uvicorn)
      printf '%s\t%s\t%s\t%s\n' "uvicorn" "ЁЯУб" "Python ASGI web server" "server" ;;
    gunicorn)
      printf '%s\t%s\t%s\t%s\n' "gunicorn" "ЁЯУб" "Python WSGI web server" "server" ;;
    java | javaw)
      printf '%s\t%s\t%s\t%s\n' "Java" "тШХ" "JVM application" "runtime" ;;
    ruby)
      printf '%s\t%s\t%s\t%s\n' "Ruby" "ЁЯТО" "Ruby interpreter" "runtime" ;;
    rust | cargo | rustc)
      printf '%s\t%s\t%s\t%s\n' "Rust" "ЁЯжА" "Rust toolchain" "runtime" ;;
    docker | dockerd | containerd | containerd-shim*)
      printf '%s\t%s\t%s\t%s\n' "Docker" "ЁЯР│" "Container runtime" "system" ;;
    postgres | postgresql | postmaster)
      printf '%s\t%s\t%s\t%s\n' "PostgreSQL" "ЁЯРШ" "Database" "server" ;;
    mysqld | mariadbd)
      printf '%s\t%s\t%s\t%s\n' "MySQL" "ЁЯРм" "Database" "server" ;;
    redis-server)
      printf '%s\t%s\t%s\t%s\n' "Redis" "ЁЯУХ" "In-memory database" "server" ;;
    mongod)
      printf '%s\t%s\t%s\t%s\n' "MongoDB" "ЁЯНГ" "Document database" "server" ;;
    nginx)
      printf '%s\t%s\t%s\t%s\n' "nginx" "ЁЯЪА" "Web server" "server" ;;
    AionUi | aion-ui)
      printf '%s\t%s\t%s\t%s\n' "AionUi" "ЁЯкЯ" "Desktop app" "app" ;;
    gnome-shell | gnome-session* | gjs | nautilus | gsd-* | gnome-software | tracker3 | tracker-extract* | evolution-* | goa-daemon)
      printf '%s\t%s\t%s\t%s\n' "GNOME" "ЁЯЦея╕П" "Desktop env (keep alive)" "system" ;;
    plasmashell | kded5 | kwin* | krunner | plasma-discover | baloo*)
      printf '%s\t%s\t%s\t%s\n' "KDE Plasma" "ЁЯЦея╕П" "Desktop env (keep alive)" "system" ;;
    Xorg | Xwayland | xwayland)
      printf '%s\t%s\t%s\t%s\n' "X server" "ЁЯЦея╕П" "Display server (keep alive)" "system" ;;
    systemd | systemd-* | init | dbus-* | polkitd | NetworkManager | wpa_supplicant | ModemManager | snapd | upowerd | gdm* | login*)
      printf '%s\t%s\t%s\t%s\n' "systemd & system" "тЪЩя╕П" "System services (keep alive)" "system" ;;
    pulseaudio | pipewire | pipewire-* | wireplumber)
      printf '%s\t%s\t%s\t%s\n' "Audio system" "ЁЯФК" "Audio daemon" "system" ;;
    bash | zsh | sh | fish | dash)
      printf '%s\t%s\t%s\t%s\n' "Shell sessions" "ЁЯРЪ" "Login shells & subshells" "shell" ;;
    gnome-terminal* | konsole | xterm | kitty | alacritty | wezterm)
      printf '%s\t%s\t%s\t%s\n' "Terminal" "ЁЯЦея╕П" "Terminal emulator" "app" ;;
    *)
      printf '%s\t%s\t%s\t%s\n' "$1" "ЁЯУж" "Process" "other" ;;
  esac
}

# Approximate Chrome tab count: renderer processes excluding extension renderers.
count_chrome_tabs() {
  local count
  count=$(pgrep -af 'chrome|chromium' 2>/dev/null |
    awk '/type=renderer/ && !/extension-process/' |
    wc -l) || count=0
  echo "${count:-0}"
}

# ---------------------------------------------------------------- top apps
top_apps() {
  local -A app_rss app_count app_emoji app_desc app_cat
  local rss comm info name emoji desc cat cur

  # `ps -eo rss,comm` puts the numeric RSS first; with `read -r rss comm`,
  # any spaces in `comm` (kernel threads like "UVM global queu", or wrapped
  # npm commands) end up in $comm as expected.
  set +u
  while read -r rss comm; do
    [[ -z "$comm" ]] && continue
    # Skip kernel threads (RSS always 0) тАФ they're not user-killable anyway.
    ((rss == 0)) && continue
    info=$(classify_app "$comm")
    IFS=$'\t' read -r name emoji desc cat <<<"$info"
    cur=${app_rss[$name]:-0}
    app_rss[$name]=$((cur + rss))
    cur=${app_count[$name]:-0}
    app_count[$name]=$((cur + 1))
    app_emoji[$name]="$emoji"
    app_desc[$name]="$desc"
    app_cat[$name]="$cat"
  done < <(ps -eo rss,comm --no-headers)
  set -u

  # Sort apps by total RSS desc тАФ write to var to avoid pipefail+head SIGPIPE.
  local sorted
  sorted=$(for name in "${!app_rss[@]}"; do
    printf '%d\t%s\n' "${app_rss[$name]}" "$name"
  done | sort -rn)

  local count=0 chrome_tabs=-1 rss name mb mb_disp extra
  while IFS=$'\t' read -r rss name; do
    ((count >= 5)) && break
    [[ -z "$name" ]] && continue

    mb=$((rss / 1024))
    if ((mb >= 1024)); then
      mb_disp=$(awk -v m="$mb" 'BEGIN{printf "%.1f GB", m/1024}')
    else
      mb_disp="${mb} MB"
    fi

    extra="${app_desc[$name]}"
    if [[ "$name" == "Chrome" || "$name" == "Chromium" || "$name" == "Brave" ]]; then
      if ((chrome_tabs < 0)); then chrome_tabs=$(count_chrome_tabs); fi
      if ((chrome_tabs > 0)); then
        extra="~${chrome_tabs} tabs"
      fi
    fi

    printf '%s %s ┬╖ %s ┬╖ %s\n' "${app_emoji[$name]}" "$name" "$mb_disp" "$extra"
    count=$((count + 1))
  done <<<"$sorted"
}

# ---------------------------------------------------------------- severity emoji
severity_emoji() {
  local pct=$1
  if ((pct < 5)); then
    echo "ЁЯФ┤"
  elif ((pct < 10)); then
    echo "ЁЯЯа"
  else
    echo "ЁЯЯб"
  fi
}

# ---------------------------------------------------------------- alert
fire_alert() {
  local apps severity body title action
  severity=$(severity_emoji "$MEM_PCT")
  apps=$(top_apps)
  title="${severity} Low memory ┬╖ ${MEM_PCT}% available"
  body=$(printf '%d MB free of %d MB ┬╖ Top apps:\n\n%s' \
    "$((MEM_AVAIL_KB / 1024))" "$((MEM_TOTAL_KB / 1024))" "$apps")

  if [[ "${XDG_CURRENT_DESKTOP:-}" == *XFCE* ]]; then
    body+=$'\n\nRun `ram-rescue open` to launch the monitor.'
  fi

  action=$(timeout 45s notify-send \
    --app-name=ram-rescue \
    --urgency=critical \
    --icon=dialog-warning \
    --wait \
    --expire-time=30000 \
    --action="open=Open Monitor" \
    --action="snooze=Snooze 30m" \
    "$title" \
    "$body" 2>/dev/null) || action=""

  case "$action" in
    open)
      detect_monitor_cmd
      if [[ -n "$MONITOR_CMD" ]]; then
        # shellcheck disable=SC2086
        nohup $MONITOR_CMD >/dev/null 2>&1 &
        logger -t ram-rescue "user opened monitor: $MONITOR_CMD"
      else
        logger -t ram-rescue "WARN: no monitor command available for desktop ${XDG_CURRENT_DESKTOP:-unknown}"
      fi
      set_quiet_window "$COOLDOWN_SEC"
      ;;
    snooze)
      set_quiet_window "$SNOOZE_DURATION"
      logger -t ram-rescue "user snoozed for ${SNOOZE_DURATION}s"
      ;;
    *)
      set_quiet_window "$COOLDOWN_SEC"
      ;;
  esac

  logger -t ram-rescue "alert pct=${MEM_PCT} avail=${MEM_AVAIL_KB}kB action=${action:-none}"
}

# ---------------------------------------------------------------- main
main() {
  read_memory
  if ((MEM_PCT >= THRESHOLD_PCT)); then
    exit 0
  fi
  if in_quiet_window; then
    exit 0
  fi
  fire_alert
}

case "${1:-}" in
  --version) echo "ram-rescue $VERSION" ;;
  --apps)
    read_memory
    severity=$(severity_emoji "$MEM_PCT")
    printf '%s Memory: %d%% available (%d MB free of %d MB)\n\nTop apps:\n\n' \
      "$severity" "$MEM_PCT" "$((MEM_AVAIL_KB / 1024))" "$((MEM_TOTAL_KB / 1024))"
    top_apps
    ;;
  --help)
    cat <<'EOF'
ram-rescue тАФ low-memory alerter for Linux desktops.

Invoked periodically by the ram-rescue.timer systemd-user unit. Reads
/proc/meminfo and fires a desktop notification when MemAvailable drops
below the configured threshold.

Use `ram-rescue` (the CLI) for status, test, and config commands.

Flags:
  --apps      Print the grouped top-apps view to stdout (no notification)
  --version   Print version
  --help      This message

Env vars:
  MEMAVAILABLE_OVERRIDE=<kB>   force a low-memory condition for testing
EOF
    ;;
  *) main ;;
esac
