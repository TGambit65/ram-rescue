#!/usr/bin/env bash
# ram-rescue — low-memory alerter for macOS.
# Invoked periodically by the com.tgambit65.ram-rescue launchd agent.

set -euo pipefail

VERSION="0.2.0"

# ---------------------------------------------------------------- config
THRESHOLD_PCT=15
COOLDOWN_SEC=600
SNOOZE_DURATION=1800
MONITOR_CMD=""

# shellcheck disable=SC1091
[[ -r "${XDG_CONFIG_HOME:-$HOME/.config}/ram-rescue/config" ]] &&
  source "${XDG_CONFIG_HOME:-$HOME/.config}/ram-rescue/config"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/ram-rescue"
QUIET_UNTIL_FILE="$STATE_DIR/quiet-until"
mkdir -p "$STATE_DIR"

# ---------------------------------------------------------------- memory check
# macOS doesn't expose MemAvailable directly. Approximate with:
#   available = free + inactive + speculative
# (Compressed pages are NOT counted as available — they're held but reclaimable.)
read_memory() {
  local page_size total_bytes free inactive spec avail_pages avail_bytes
  page_size=$(sysctl -n hw.pagesize)
  total_bytes=$(sysctl -n hw.memsize)

  free=$(vm_stat | awk '/Pages free:/{gsub(/\.$/,"",$3); print $3}')
  inactive=$(vm_stat | awk '/Pages inactive:/{gsub(/\.$/,"",$3); print $3}')
  spec=$(vm_stat | awk '/Pages speculative:/{gsub(/\.$/,"",$3); print $3}')

  avail_pages=$((free + inactive + spec))
  avail_bytes=$((avail_pages * page_size))

  MEM_TOTAL_KB=$((total_bytes / 1024))
  MEM_AVAIL_KB=${MEMAVAILABLE_OVERRIDE:-$((avail_bytes / 1024))}
  MEM_PCT=$((MEM_AVAIL_KB * 100 / MEM_TOTAL_KB))
}

# ---------------------------------------------------------------- quiet window
in_quiet_window() {
  [[ -f "$QUIET_UNTIL_FILE" ]] || return 1
  local quiet_until now
  quiet_until=$(<"$QUIET_UNTIL_FILE")
  now=$(date +%s)
  ((quiet_until > now))
}

set_quiet_window() {
  local duration=$1
  echo "$(($(date +%s) + duration))" >"$QUIET_UNTIL_FILE"
}

# ---------------------------------------------------------------- top consumers
top_consumers() {
  ps -axo rss,comm | awk '
    NR > 1 {
      # comm may contain spaces (e.g. "/Applications/Foo.app/.../bar"); take basename
      n = split($2, parts, "/")
      cmd = parts[n]
      a[cmd] += $1
    }
    END {
      n = 0
      for (k in a) keys[n++] = k
      for (i = 1; i < n; i++) {
        cur = keys[i]; j = i - 1
        while (j >= 0 && a[keys[j]] < a[cur]) { keys[j+1] = keys[j]; j-- }
        keys[j+1] = cur
      }
      lim = (n < 5) ? n : 5
      for (i = 0; i < lim; i++)
        printf "  %-22s %5d MB\n", keys[i], int(a[keys[i]]/1024)
    }
  '
}

# ---------------------------------------------------------------- alert
fire_alert() {
  local top body
  top=$(top_consumers)
  body=$(printf 'Available: %d%% (%d MB)\n\nTop consumers:\n%s\n\nRun `ram-rescue open` in Terminal to launch Activity Monitor.' \
    "$MEM_PCT" "$((MEM_AVAIL_KB / 1024))" "$top")

  # macOS Notification Center (no action buttons — that requires a Cocoa app).
  # The body text instructs the user to run `ram-rescue open`.
  /usr/bin/osascript <<APPLESCRIPT 2>/dev/null || true
display notification "$body" with title "ram-rescue: Low memory ($MEM_PCT% available)" sound name "Submarine"
APPLESCRIPT

  set_quiet_window "$COOLDOWN_SEC"

  /usr/bin/logger -t ram-rescue "alert pct=${MEM_PCT} avail=${MEM_AVAIL_KB}kB"
}

# ---------------------------------------------------------------- main
main() {
  read_memory
  if ((MEM_PCT >= THRESHOLD_PCT)); then
    exit 0
  fi
  if in_quiet_window; then
    exit 0
  fi
  fire_alert
}

case "${1:-}" in
  --version) echo "ram-rescue $VERSION" ;;
  --help)
    cat <<'EOF'
ram-rescue (macOS) — low-memory alerter for macOS.

Invoked periodically by the com.tgambit65.ram-rescue launchd agent.
Use `ram-rescue` (the CLI) for status, test, and config commands.

Env vars:
  MEMAVAILABLE_OVERRIDE=<kB>   force a low-memory condition for testing
EOF
    ;;
  *) main ;;
esac
